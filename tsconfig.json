{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"],
			// ===Features===
			"@features/*": ["./src/features/*"],

			// ===Shared===
			// Components
			"@ui/*": ["./src/shared/components/ui/*"],
			"@forms/*": ["./src/shared/components/forms/*"],

			// Utils
			"@utils/*": ["./src/shared/utils/*"],

			// Validations
			"@validations/*": ["./src/shared/validations/*"],

			// ===Libs===
			"@lib/*": ["./src/lib/*"],

			// ===Data Base===
			"@db": ["./src/db"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
